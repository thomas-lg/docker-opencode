<?xml version="1.0"?>
<Container version="2">
  <Name>open-code</Name>
  <Repository>ghcr.io/thomas-lg/docker-opencode:latest</Repository>
  <Registry>https://github.com/thomas-lg/docker-opencode/pkgs/container/docker-opencode</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <ReadMe/>
  <Overview/>
  <Category/>
  <WebUI>http://[IP]:[PORT:4096]</WebUI>
  <TemplateURL/>
  <Icon>https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/opencode.png</Icon>
  <ExtraParams/>
  <PostArgs>web --hostname 0.0.0.0 --port 4096</PostArgs>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Web GUI" Target="4096" Default="4096" Mode="tcp" Description="" Type="Port" Display="always" Required="false" Mask="false">4096</Config>
  <Config Name="Configuration" Target="/root/.config/opencode" Default="/mnt/user/appdata/opencode/config" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/opencode/config</Config>
  <Config Name="Sessions &amp;amp; logs" Target="/root/.local/share/opencode" Default="/mnt/user/appdata/opencode/data" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/opencode/data</Config>
  <Config Name="State" Target="/root/.local/state/opencode" Default="/mnt/user/appdata/opencode/state" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/opencode/state  </Config>
  <Config Name="Docker Socket Proxy" Target="DOCKER_HOST" Default="dockersocket" Mode="" Description="" Type="Variable" Display="always" Required="false" Mask="false">dockersocket</Config>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="" Type="Variable" Display="always" Required="false" Mask="false">99</Config>
  <Config Name="GUID" Target="GUID" Default="100" Mode="" Description="" Type="Variable" Display="always" Required="false" Mask="false">100</Config>
  <Config Name="Vaultwarden Server URL" Target="BW_SERVER_URL" Default="" Mode="" Description="URL of your Vaultwarden instance" Type="Variable" Display="always" Required="true" Mask="false"></Config>
  <Config Name="Bitwarden Client ID" Target="BW_CLIENTID" Default="" Mode="" Description="API client_id for Bitwarden login" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="Bitwarden Client Secret" Target="BW_CLIENTSECRET" Default="" Mode="" Description="API client_secret for Bitwarden login" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="Bitwarden Master Password" Target="BW_PASSWORD" Default="" Mode="" Description="Master password to unlock the vault" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <TailscaleStateDir/>
</Container>
